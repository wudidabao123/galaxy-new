# Galaxy New — Environment Variables
# Copy this file to .env and fill in your values.

# Default API Key (used when no keyring entry exists)
GALAXY_DEFAULT_API_KEY=sk-your-key-here
GALAXY_DEFAULT_BASE_URL=https://api.deepseek.com

# SQLite database path (default: ./galaxy.db)
GALAXY_DB_PATH=galaxy.db

# Log level
GALAXY_LOG_LEVEL=INFO
